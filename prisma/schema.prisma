generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model buddy_requests {
  id                                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                               String       @db.Uuid
  receiver_id                             String       @db.Uuid
  travel_plan_id                          String       @db.Uuid
  message                                 String?
  status                                  String?      @default("pending")
  created_at                              DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime?    @default(now()) @db.Timestamptz(6)
  travel_plans                            travel_plans @relation(fields: [travel_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sender_id, travel_plan_id])
  @@schema("public")
}

model profiles {
  id                      String       @id @db.Uuid
  bio                     String?
  avatar_url              String?
  country                 String?
  is_admin                Boolean?     @default(false)
  is_premium              Boolean?     @default(false)
  is_verified             Boolean?     @default(false)
  subscription_tier       String?
  subscription_expires_at DateTime?    @db.Timestamptz(6)
  stripe_customer_id      String?
  created_at              DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?    @default(now()) @db.Timestamptz(6)
  profile_picture         String?
  email                   String       @unique @default("")
  visited_countries       String[]
  travel_interests        String[]
  isDeleted               Boolean      @default(false)
  full_name               String?
  phone                   String?      @unique(map: "profiles_phone_number_key") @default("")
  providers               String[]
  is_password             Boolean?
  travel_plans_id         String[]     @unique
  username_slug           String?      @unique
  travel_plans            travel_plans[]

  @@schema("public")
}

model reviews {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewer_id    String        @db.Uuid
  rating         Int
  comment        String?
  travel_plan_id String?       @db.Uuid
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?     @default(now()) @db.Timestamptz(6)
  travel_plans   travel_plans? @relation(fields: [travel_plan_id], references: [id], onUpdate: NoAction)

  @@schema("public")
}

model travel_plans {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String           @db.Uuid
  title             String
  start_date        String  
  end_date          String        
  description       String?
  min_budget        Int?
  max_budget        Int?
  looking_for_buddy Boolean?         @default(true)
  max_buddies       Int?             @default(1)
  status            String?          @default("active")
  created_at        DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?        @default(now()) @db.Timestamptz(6)
  travel_type       String?
  image             String?
  tags              String[]
  country           String
  city              String
  slug              String?          @unique
  buddy_requests    buddy_requests[]
  reviews           reviews[]
  participantsId    String[]
  profiles          profiles? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model country_lists{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String
  iso2 String
  iso3 String
  phoneCode String
  region String

  @@schema("public")
}