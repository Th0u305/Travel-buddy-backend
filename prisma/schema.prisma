generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model buddy_requests {
  id                                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id                               String       @db.Uuid
  receiver_id                             String       @db.Uuid
  travel_plan_id                          String       @db.Uuid
  message                                 String?
  status                                  String?      @default("pending")
  created_at                              DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime?    @default(now()) @db.Timestamptz(6)
  travel_plans                            travel_plans @relation(fields: [travel_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sender_id, travel_plan_id])
  @@schema("public")
}

model profiles {
  id                      String       @id @db.Uuid
  bio                     String?
  avatar_url              String?
  country                 String?
  is_admin                Boolean?     @default(false)
  is_premium              Boolean?     @default(false)
  is_verified             Boolean?     @default(false)
  subscription_tier       String?
  subscription_expires_at DateTime?    @db.Timestamptz(6)
  subscription_plan       String?
  created_at              DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?    @default(now()) @db.Timestamptz(6)
  email                   String       @unique @default("")
  visited_countries       String[]
  travel_interests        String[]
  isDeleted               Boolean      @default(false)
  full_name               String?
  phone                   String?      @unique(map: "profiles_phone_number_key") @default("")
  providers               String[]
  is_password             Boolean?
  username_slug           String?      @unique(map: "profiles_slug_key")
  deleted_log             deleted_log?
  payments                payments[]
  travel_plans            travel_plans[]

  @@schema("public")
}

model reviews {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewer_id    String        @db.Uuid
  rating         Int
  comment        String?
  travel_plan_id String?       @db.Uuid
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?     @default(now()) @db.Timestamptz(6)
  travel_plans   travel_plans? @relation(fields: [travel_plan_id], references: [id], onUpdate: NoAction)

  @@schema("public")
}

model travel_plans {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String           @db.Uuid
  title             String
  start_date        DateTime         @db.Timestamptz(6)
  end_date          DateTime         @db.Timestamptz(6)
  description       String?
  min_budget        Int?
  max_budget        Int?
  looking_for_buddy Boolean?         @default(true)
  max_buddies       Int?             @default(1)
  status            String?          @default("active")
  created_at        DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?        @default(now()) @db.Timestamptz(6)
  travel_type       String?
  image             String?
  tags              String[]
  country           String
  city              String
  slug              String?          @unique
  participantsId    String[]
  buddy_requests    buddy_requests[]
  reviews           reviews[]
  profiles          profiles         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model country_lists {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  name       String?  @unique
  iso2       String?  @unique
  iso3       String?  @unique
  phoneCode  String?
  region     String?

  @@schema("public")
}


model deleted_log {
  deleted_id     String   @id @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  user_email     String?
  is_deleted     Boolean? @default(false)
  deleted_reason String?
  profiles       profiles @relation(fields: [deleted_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model payments {
  id             BigInt    @id @default(autoincrement())
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @db.Timestamptz(6)
  user_id        String?   @db.Uuid
  transaction_id String[]
  status         String?   @db.VarChar
  profiles       profiles? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}